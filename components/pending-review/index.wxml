<view class="review-root">
  <view class="review-topbar">
    <view class="topbar-side topbar-left" bindtap="onBack">
      <van-icon name="arrow-left" size="22px" color="#FFFFFF" />
      <text class="back-text">返回</text>
    </view>
    <view class="topbar-title">待审核</view>
    <view class="topbar-side"></view>
  </view>

  <scroll-view class="review-list" scroll-y="true" show-scrollbar="false">
    <view wx:if="{{loading}}" class="review-empty">加载中...</view>
    <view wx:elif="{{!reviewers.length}}" class="review-empty">暂无待审核报名</view>

    <block wx:else>
      <view
        wx:for="{{reviewers}}"
        wx:key="registrationId"
        class="review-card"
        data-index="{{index}}"
        bindtap="onOpenDetail"
      >
        <image class="avatar" src="{{item.avatarUrl}}" mode="aspectFill" />

        <view class="review-main">
          <view class="review-head">
            <text class="review-name">{{item.nickname}}</text>
            <text class="review-time">{{item.appliedText}}</text>
          </view>
          <view class="activity-title">{{item.activityTitle}}</view>
          <view class="application-preview">{{item.applicationPreview}}</view>
        </view>

        <view class="review-arrow">
          <van-icon name="arrow" size="20px" color="rgba(255,255,255,0.48)" />
        </view>
      </view>
    </block>
  </scroll-view>

  <van-popup
    show="{{showDetail}}"
    round
    position="bottom"
    lock-scroll
    custom-style="padding: 22px 16px calc(22px + env(safe-area-inset-bottom)); background: rgb(46,46,46);"
    bind:close="onCloseDetail"
  >
    <view wx:if="{{selectedReview}}" class="review-detail">
      <view class="detail-title">报名详情</view>
      <view class="detail-user">
        <image class="detail-avatar" src="{{selectedReview.avatarUrl}}" mode="aspectFill" />
        <view class="detail-user-main">
          <view class="detail-name">{{selectedReview.nickname}}</view>
          <view class="detail-activity">{{selectedReview.activityTitle}}</view>
        </view>
      </view>

      <view class="detail-section">
        <view class="detail-label">报名申请</view>
        <view class="detail-text">{{selectedReview.fullApplicationText}}</view>
      </view>

      <view class="detail-section">
        <view class="detail-label">用户评价</view>
        <view class="detail-rating-list">
          <view class="detail-rating-row">
            <text>综合评分</text>
            <text>{{selectedReview.overallRatingText}}</text>
            <van-icon name="star" size="28rpx" color="#FFD60A" />
          </view>
        </view>
      </view>

      <view class="detail-actions">
        <button
          class="detail-btn detail-btn--reject"
          data-id="{{selectedReview.registrationId}}"
          disabled="{{actingId}}"
          bindtap="onReject"
        >拒绝</button>
        <button
          class="detail-btn detail-btn--approve"
          data-id="{{selectedReview.registrationId}}"
          disabled="{{actingId}}"
          bindtap="onApprove"
        >通过</button>
      </view>
    </view>
  </van-popup>
</view>
